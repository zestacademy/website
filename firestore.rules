rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper function to check if user is an Admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'zestacademyonline@gmail.com' ||
        request.auth.token.email == 'zestacademy@rsmk.co.in' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Helper function to check if user is an Instructor
    function isInstructor() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor';
    }

    // Allow collection group queries for comments for admins
    match /{path=**}/comments/{commentId} {
      allow read: if isAdmin();
    }

    // Helper function to validate comment content
    function isValidComment() {
      return request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 2000
        && request.resource.data.author is string
        && request.resource.data.timestamp != null;
    }

    // --- Users Collection & Subcollections ---
    match /users/{userId} {
      // Allow users to create their own profile when authenticated
      allow create: if isSignedIn();
      // Instructors can only read student profiles, not other admins/instructors
      allow read: if isOwner(userId) || isAdmin() || 
                  (isInstructor() && resource.data.role == 'student');
      allow update: if isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'suspended', 'zestId']));
      allow delete: if isAdmin();
      
      // Allow access to all subcollections of user (e.g. enrolledCourses, courseProgress, etc)
      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- LMS: Enrollments & Progress ---
    // Root level enrollments (lms-service.ts)
    match /enrollments/{enrollmentId} {
      // Fixed: Students can only read their own enrollments
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid &&
                    (request.resource.data.paymentStatus == 'pending' || get(/databases/$(database)/documents/courses/$(request.resource.data.courseId)).data.price == 0);
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['paymentStatus', 'amount', 'courseId']));
      allow delete: if isAdmin();

      match /quiz_attempts/{attemptId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/enrollments/$(enrollmentId)).data.userId == request.auth.uid;
      }
    }

    // --- Leaderboards ---
    match /leaderboards/{roadmapId}/users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // --- Community: Discussions ---
    match /discussions/{discussionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      match /replies/{replyId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();
      }
    }

    // --- Contact Messages ---
    match /contact_messages/{messageId} {
      allow create: if request.resource.data.keys().hasAll(['email']) && request.resource.data.email is string;
      allow read, delete: if isAdmin();
    }

    // --- Developer Applications ---
    match /developer_applications/{applicationId} {
      allow create: if request.resource.data.keys().hasAll(['email']) && request.resource.data.email is string;
      allow read, delete: if isAdmin();
    }

    // --- Course Management ---
    match /courses/{courseId} {
      allow read: if true;
      allow create: if isAdmin() || (isInstructor() && request.resource.data.instructorId == request.auth.uid);
      allow update, delete: if isAdmin() || (isInstructor() && resource.data.instructorId == request.auth.uid);

      // databaseService.ts uses standard subcollections
      match /enrollments/{uid} {
        allow read: if isOwner(uid) || isAdmin() || (isInstructor() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
        allow write: if isAdmin();
      }

      match /liveClasses/{classId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isInstructor();

        match /feedback/{feedbackId} {
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow read, update, delete: if isAdmin() || isInstructor();
        }
      }
    }

    // --- Live Sessions (lms-service.ts) ---
    match /liveSessions/{sessionId} {
      allow read: if true;
      // Fixed: Ensure instructorId matches creator
      allow create: if isAdmin() || (isInstructor() && request.resource.data.instructorId == request.auth.uid);
      allow update, delete: if isAdmin() || (isInstructor() && resource.data.instructorId == request.auth.uid);
    }

    // --- Attendance (lms-service.ts) ---
    match /attendance/{attendanceId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin() || isInstructor();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isInstructor();
    }

    // --- Certificates (lms-service.ts) ---
    match /certificates/{certId} {
      allow read: if true; // Publicly verifiable
      allow write: if isAdmin() || isInstructor();
    }

    // --- Payments (lms-service.ts) ---
    match /payments/{paymentId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if false; // Only secure backend should create payments
      allow update, delete: if isAdmin();
    }

    // --- Notifications & Configs ---
    match /courseConfigs/{configId} {
      allow read: if true;
      allow write: if isAdmin() || isInstructor();
    }

    match /notificationSubscriptions/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isInstructor();
    }

    // --- Newsletter & Leads ---
    match /newsletterSubscribers/{subscriberId} {
      allow create, update: if request.resource.data.email is string;
      allow read, delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(['email']) && request.resource.data.email is string;
      allow read, update, delete: if isAdmin();
    }

    // --- Articles & Existing Comments ---
    match /articles/{articleId}/comments/{commentId} {
      allow read: if true;
      allow create: if isValidComment() && request.resource.data.timestamp == request.time;
      allow update: if isOwner(resource.data.authorId) && isValidComment() && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    match /articles/{articleId} {
      allow read: if false;
      allow write: if false;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}